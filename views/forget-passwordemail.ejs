<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password</title>

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body{
            height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            background:linear-gradient(135deg,#74ebd5,#9face6);
        }

        .container{
            width:400px;
            background:white;
            padding:40px;
            border-radius:15px;
            box-shadow:0 10px 25px rgba(0,0,0,0.2);
        }

        h1{
            text-align:center;
            margin-bottom:15px;
            color:#333;
        }

        .subtitle{
            text-align:center;
            color:#666;
            margin-bottom:25px;
            font-size:14px;
        }

        .form-group{
            display:flex;
            flex-direction:column;
            margin-bottom:20px;
        }

        label{
            margin-bottom:8px;
            font-weight:bold;
            color:#555;
        }

        input{
            padding:12px;
            border:1px solid #ccc;
            border-radius:8px;
            font-size:16px;
            outline:none;
        }

        input:focus{
            border-color:rgb(233, 180, 21);
        }

        button{
            width:100%;
            padding:12px;
            border:none;
            border-radius:8px;
            background:rgb(233, 180, 21);
            color:white;
            font-size:16px;
            cursor:pointer;
            transition:0.3s;
        }

        button:hover{
            background:rgb(176, 136, 14);
        }

        .error{
            margin-top:15px;
            text-align:center;
            color:red;
            font-weight:bold;
        }

        .back-link{
            text-align:center;
            margin-top:18px;
        }

        .back-link a{
            text-decoration:none;
            color:#4f46e5;
            font-weight:bold;
        }

    </style>

</head>
<body>

    <div class="container">

        <h1>Forgot Password</h1>

        <p class="subtitle">
            Enter your email address and we'll send you an OTP
        </p>

        <form action="/users/sent-otp" method="POST">

            <div class="form-group">

                <label for="email">
                    Email Address
                </label>

                <input
                    type="email"
                    name="email"
                    id="email"
                    placeholder="Enter your email"
                    required
                >

            </div>

            <button type="submit">
                Send OTP
            </button>

        </form>

        <% if(locals.error){ %>
            <p class="error">
                <%= error %>
            </p>
        <% } %>

        <div class="back-link">
            <a href="/login">Back to Login</a>
        </div>

    </div>

</body>
</html>